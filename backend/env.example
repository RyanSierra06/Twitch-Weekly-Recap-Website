# Production Environment Variables
NODE_ENV=production

# Frontend URL (your Vercel app)
FRONTEND_BASE_URL=https://twitch-weekly-recap.vercel.app

# Session Configuration
SESSION_SECRET=your-very-long-random-secret-key-here

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Twitch OAuth Configuration
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_SECRET=your_twitch_client_secret
TWITCH_CALLBACK_URL=https://your-backend-domain.onrender.com/auth/twitch/callback

# Server Configuration
PORT=4000
